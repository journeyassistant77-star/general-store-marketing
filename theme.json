{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },
    "color": {
      "palette": [
        { "slug": "background", "color": "#0b0b0d", "name": "Background" },
        { "slug": "surface",    "color": "#16161a", "name": "Surface" },
        { "slug": "foreground", "color": "#f5f5f7", "name": "Foreground" },
        { "slug": "muted",      "color": "#9a9aa3", "name": "Muted" },
        { "slug": "accent",     "color": "#ff6a1a", "name": "Accent" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "sans",
          "name": "Sans",
          "fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "small",  "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1rem",     "name": "Medium" },
        { "slug": "large",  "size": "1.5rem",   "name": "Large" },
        { "slug": "xlarge", "size": "2.5rem",   "name": "X-Large" },
        { "slug": "xxlarge","size": "4rem",     "name": "XX-Large" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--accent)" }
      },
      "h1": { "typography": { "fontSize": "var(--wp--preset--font-size--xxlarge)", "lineHeight": "1.1" } },
      "h2": { "typography": { "fontSize": "var(--wp--preset--font-size--xlarge)",  "lineHeight": "1.2" } }
    }
  }
}
